{
  "manifest_version": 3,
  "name": "AI Fake Job Detector",
  "version": "1.0",
  "description": "Detect fake job postings on job websites",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}